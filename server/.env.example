PORT=5000
NODE_ENV=development
MONGODB_URI=
JWT_SECRET=
FRONTEND_URL=http://localhost:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_FRONTEND_CALLBACK_PATH=/auth/google/callback
BCRYPT_SALT_ROUNDS=10
REDIS_URL=
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_LOGIN_IP=50
RATE_LIMIT_LOGIN_EMAIL=10
NEGATIVE_CACHE_TTL_SEC=30
CORS_MAX_AGE_SEC=600
LOGIN_CACHE_TTL_SEC=120
HEALTH_WARMUP_INTERVAL_SEC=300

# Gemini AI
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=90000
GEMINI_MAX_RETRIES=2
GEMINI_MAX_OUTPUT_TOKENS=2048

# Review limits
REVIEW_DAILY_LIMIT=5
REVIEW_CACHE_TTL_SEC=43200

# Project analyzer limits
ANALYZE_DAILY_LIMIT=3
ANALYZE_CACHE_TTL_SEC=21600
ANALYZE_MAX_FILE_SIZE=40000
ANALYZE_MAX_TOTAL_SIZE=200000

# L1 in-memory cache (in front of Redis)
L1_CACHE_MAX=200
L1_CACHE_TTL_MS=3600000
